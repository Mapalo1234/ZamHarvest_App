<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="css/orderTable.css">
  <link rel="stylesheet" href="css/requestDashboard.css">
   <link rel="stylesheet" href="all/css/font-awesome.min.css">
     <link rel="stylesheet" href="css/nav.css">
    <link rel="stylesheet" href="css/loader.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css">
  <title>Request Management</title>
</head>
<body>

  <header id="navbar">
    <nav>
      <a class="logo" href="/home">ZamHarvest</a>
      <ul class="menu">
        <li><a href="/home">Home</a></li>
        <li><a href="/view">Dashboard</a></li>
        <li><a href="/orderTable">Requests</a></li>
      </ul>
    </nav>
    <div class="login"><i class="fa fa-user-circle-o" aria-hidden="true"></i></div>
     <div class="notfication-logo"><i class="fa fa-bell" aria-hidden="true"></i></div>
  </header>

<div class="container">

  <h2>cRequests</h2>
 <table class="request-table">
  <thead>
    <tr>
      <th>Product</th>
      <th>Buyer</th>
      <th>Quantity</th>
      <th>Unit</th>
      <th>Total Price</th>
      <th>Delivery Date</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody class="orderInfo"></tbody>
</table>


  <div id="editPriceModal" class="modal" style="display:none;">
    <div class="modal-content">
      <span class="close">&times;</span>
      <h3>Edit Total Price</h3>
      <input type="number" id="newPriceInput" min="0" />
      <button id="savePriceBtn">Save</button>
    </div>
  </div>

  <div id="noteModal" class="modal" style="display:none;">
    <div class="modal-content">
      <span class="close">&times;</span>
      <h3>Add Note</h3>
      <textarea id="noteInput" rows="4"></textarea>
      <button id="saveNoteBtn">Save Note</button>
    </div>
  </div>

  <footer>
    <span class="showEntries"></span>
    <div class="pagination"></div>
  </footer>
</div>
   <div class="loader-container" id="loader" style="display: none;">
  <span class="loader"></span>

{{!-- <script src="js/orderTable.js"></script> --}}
<script src="js/requestDashboard.js"></script>
</body>
</html>
