<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <link rel="stylesheet" href="css/orderTable.css">
   <link rel="stylesheet" href="all/css/font-awesome.min.css">
     <link rel="stylesheet" href="css/nav.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css">
  <title>Order Management</title>
</head>
<body>

  <header id="navbar">
    <nav>
      <a class="logo" href="index.html">ZamHarvest</a>
      <ul class="menu">
        <li><a href="/home">Home</a></li>
        <li><a href="/view">Seller</a></li>
        <li><a href="/orderTable">Orders</a></li>
        <li><a href="#">About</a></li>
        <li><a href="#">Blog</a></li>
      </ul>
    </nav>
    <div class="login"><i class="fa fa-user-circle-o" aria-hidden="true"></i></div>
     <div class="notfication-logo"><i class="fa fa-bell" aria-hidden="true"></i></div>
  </header>

<div class="container">

  <table>
    <thead>
      <tr class="heading">
        <th>Image</th>
        <th>Product Name</th>
        <th>Total Price</th>
        <th>Quantity</th>
        <th>Seller</th>
        <th>Paid Status</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody class="orderInfo"></tbody>
  </table>

  <footer>
    <span class="showEntries"></span>
    <div class="pagination"></div>
  </footer>
</div>

<!-- Popup Form -->
<div class="dark_bg">
  <div class="popup">
    <header>
      <h2 class="modalTitle">Fill the Form</h2>
      <button class="closeBtn">&times;</button>
    </header>
    <div class="body">
      <form id="orderForm">
        <div class="imgholder">
          <img src="./img/pic1.png" alt="Order Image" width="150" height="150" class="img">
        </div>
        <div class="inputFieldContainer">
          <div class="form_control">
            <label for="productName">Product Name:</label>
            <input type="text" id="productName" required>
          </div>
          <div class="form_control">
            <label for="totalPrice">Total Price:</label>
            <input type="number" id="totalPrice" required>
          </div>
          <div class="form_control">
            <label for="quantity">Quantity:</label>
            <input type="number" id="quantity" required>
          </div>
          <div class="form_control">
            <label for="seller">Seller:</label>
            <input type="text" id="seller" required>
          </div>
          <div class="form_control">
            <label for="paidStatus">Paid Status:</label>
            <select id="paidStatus" required>
            </select>
          </div>
        </div>
      </form>
    </div>
    <footer class="popupFooter">
      <button form="orderForm" class="submitBtn">Submit</button>
    </footer>
  </div>
</div>

<script src="js/orderTable.js"></script>
</body>
</html>
